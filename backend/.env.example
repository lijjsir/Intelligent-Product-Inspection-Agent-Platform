PIAP_VISION_DETECTOR_URL=
PIAP_VISION_DETECTOR_API_KEY=
PIAP_VISION_DETECTOR_TIMEOUT_SEC=20
PIAP_GOVERNANCE_SECRET=piap-governance-secret

PIAP_LANGFUSE_ENABLED=true
PIAP_LANGFUSE_PUBLIC_KEY=pk-lf-piap-local
PIAP_LANGFUSE_SECRET_KEY=sk-lf-piap-local-secret
