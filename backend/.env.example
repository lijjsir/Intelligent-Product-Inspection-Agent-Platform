PIAP_APP_ENV=local
PIAP_APP_NAME=piap-backend
PIAP_APP_HOST=0.0.0.0
PIAP_APP_PORT=8000
PIAP_APP_LOG_LEVEL=info

PIAP_DB_URL=mysql+aiomysql://piap:piap@127.0.0.1:3306/piap_main
PIAP_DB_REPLICA_URL=mysql+aiomysql://piap:piap@127.0.0.1:3306/piap_main

PIAP_REDIS_URL=redis://127.0.0.1:16379/0
PIAP_CELERY_BROKER_URL=redis://127.0.0.1:16379/0
PIAP_CELERY_RESULT_BACKEND=redis://127.0.0.1:16379/0

PIAP_JWT_PRIVATE_KEY=change_me_private_key
PIAP_JWT_PUBLIC_KEY=change_me_public_key
PIAP_JWT_ISSUER=piap
PIAP_JWT_AUDIENCE=piap-users
PIAP_JWT_EXP_MINUTES=15
PIAP_JWT_REFRESH_DAYS=7

PIAP_S3_ENDPOINT=http://127.0.0.1:19000
PIAP_S3_ACCESS_KEY=piap
PIAP_S3_SECRET_KEY=piap_password
PIAP_S3_BUCKET=piap
PIAP_QDRANT_URL=http://127.0.0.1:6333
PIAP_QDRANT_COLLECTION=piap_standard_book

PIAP_VOLCENGINE_API_KEY=
PIAP_VOLCENGINE_MODEL_ID=
PIAP_VOLCENGINE_EMBED_MODEL=
